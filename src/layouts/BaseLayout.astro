---
import '../styles/global.css';
import {
  getLoaderScript,
  getInitialStyles,
  getFontFaceStyles,
  getFontLinks,
  getComponentChunkLinks,
  getIconLinks,
} from '@porsche-design-system/components-js/partials';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Gemeinschaftspraxis Soika – Ihre Hausarztpraxis mit zwei Standorten in Schopfloch und Dornstetten.' } = Astro.props;

const navItems = [
  { label: 'Startseite', href: '#' },
  { label: 'Unsere Praxis', href: '#praxis' },
  { label: 'Leistungen', href: '#leistungen' },
  { label: 'Team', href: '#team' },
  { label: 'Aktuelles', href: '#aktuelles' },
  { label: 'Kontakt', href: '#kontakt' },
];

const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <Fragment set:html={getInitialStyles()} />
  <Fragment set:html={getFontFaceStyles()} />
  <Fragment set:html={getFontLinks()} />
  <Fragment set:html={getComponentChunkLinks()} />
  <Fragment set:html={getIconLinks()} />
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body class="bg-white text-gray-900">
  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
    <nav class="max-w-[1280px] mx-auto px-6 h-20 flex items-center justify-between">
      <!-- Logo -->
      <a href={base} class="flex items-center gap-2">
        <div class="flex flex-col">
          <span class="text-2xl font-bold tracking-wide text-primary">SOIKA</span>
          <span class="text-[10px] uppercase tracking-[0.2em] text-gray-500">Gemeinschaftspraxis</span>
        </div>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded"
        aria-label="Menu offnen"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

      <!-- Desktop nav -->
      <ul class="hidden lg:flex items-center gap-8">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="text-sm text-gray-700 hover:text-primary transition-colors font-medium">
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA buttons -->
      <div class="hidden lg:flex items-center gap-4">
        <a href="tel:074439550" class="flex items-center gap-2 text-sm text-gray-700 hover:text-primary transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          07443 9550
        </a>
        <a href="#kontakt" class="bg-primary text-white px-5 py-2.5 rounded-full text-sm font-medium hover:bg-primary-light transition-colors">
          Termin vereinbaren
        </a>
      </div>
    </nav>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
      <ul class="px-6 py-4 space-y-3">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="block text-sm text-gray-700 hover:text-primary transition-colors font-medium py-1">
              {item.label}
            </a>
          </li>
        ))}
        <li class="pt-3 border-t border-gray-100">
          <a href="tel:074439550" class="flex items-center gap-2 text-sm text-gray-700 py-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            07443 9550
          </a>
        </li>
        <li>
          <a href="#kontakt" class="inline-block bg-primary text-white px-5 py-2.5 rounded-full text-sm font-medium">
            Termin vereinbaren
          </a>
        </li>
      </ul>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-primary text-white py-16">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-12">
        <div>
          <p class="text-xl font-bold mb-2">SOIKA</p>
          <p class="text-sm text-white/70 uppercase tracking-wider">Gemeinschaftspraxis</p>
          <p class="text-sm text-white/60 mt-4">Ihre hausärztliche Versorgung an den Standorten Schopfloch und Dornstetten.</p>
        </div>
        <div>
          <h4 class="font-semibold mb-4">Kontakt</h4>
          <p class="text-sm text-white/70 mb-1">Tel: 07443 9550</p>
          <p class="text-sm text-white/70 mb-1">Fax: 07443 9551</p>
          <p class="text-sm text-white/70">praxis@gemeinschaftspraxis-soika.de</p>
        </div>
        <div>
          <h4 class="font-semibold mb-4">Rechtliches</h4>
          <div class="flex flex-col gap-2 text-sm">
            <a href={`${base}/impressum`} class="text-white/70 hover:text-white transition-colors">Impressum</a>
            <a href={`${base}/datenschutz`} class="text-white/70 hover:text-white transition-colors">Datenschutz</a>
          </div>
        </div>
      </div>
      <div class="border-t border-white/20 mt-12 pt-6">
        <p class="text-sm text-white/50">&copy; {new Date().getFullYear()} Gemeinschaftspraxis Soika. Alle Rechte vorbehalten.</p>
      </div>
    </div>
  </footer>

  <Fragment set:html={getLoaderScript()} />

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
    menu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.add('hidden');
      });
    });
  </script>
</body>
</html>
