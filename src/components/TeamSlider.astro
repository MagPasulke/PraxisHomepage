---
interface Props {
  aerzte: Array<{ name: string; role: string; description: string; image: string }>;
  mfa: Array<{ name: string; role: string; image: string }>;
}

const { aerzte, mfa } = Astro.props;
---

<div class="space-y-fluid-lg">
  <!-- Ärzteteam Carousel -->
  <p-carousel heading="Ärzteteam" slides-per-page="4" intl="{'slideLabel': 'Slide %s von %s', 'prev': 'Vorheriger Slide', 'next': 'Nächster Slide', 'first': 'Zum ersten Slide', 'last': 'Zum letzten Slide'}">
    {aerzte.map((person) => (
      <div class="cursor-pointer group team-card-arzt" data-name={person.name} data-description={person.description}>
        <div class="aspect-[3/4] bg-surface-alt rounded-lg overflow-hidden mb-static-sm">
          <div class="w-full h-full flex items-center justify-center text-contrast-low text-5xl">
            👤
          </div>
        </div>
        <h4 class="prose-text-sm font-semibold group-hover:text-primary transition-colors">{person.name}</h4>
        <p class="prose-text-xs text-contrast-medium">{person.role}</p>
      </div>
    ))}
  </p-carousel>

  <!-- MFA Carousel -->
  <p-carousel heading="Medizinische Fachangestellte" slides-per-page="5" intl="{'slideLabel': 'Slide %s von %s', 'prev': 'Vorheriger Slide', 'next': 'Nächster Slide', 'first': 'Zum ersten Slide', 'last': 'Zum letzten Slide'}">
    {mfa.map((person) => (
      <div>
        <div class="aspect-square bg-surface-alt rounded-lg overflow-hidden mb-static-sm">
          <div class="w-full h-full flex items-center justify-center text-contrast-low text-4xl">
            👤
          </div>
        </div>
        <h4 class="prose-text-xs font-semibold">{person.name}</h4>
        <p class="prose-text-xs text-contrast-medium">{person.role}</p>
      </div>
    ))}
  </p-carousel>
</div>

<!-- Team detail flyout -->
<p-modal id="team-modal" heading="" open="false">
  <p id="team-modal-desc" class="prose-text-sm text-contrast-medium"></p>
</p-modal>

<script>
  const modal = document.getElementById('team-modal') as any;
  const modalDesc = document.getElementById('team-modal-desc');

  document.querySelectorAll('.team-card-arzt').forEach(card => {
    card.addEventListener('click', () => {
      const name = card.getAttribute('data-name') || '';
      const desc = card.getAttribute('data-description') || '';
      if (modal) {
        modal.heading = name;
        modal.open = true;
      }
      if (modalDesc) modalDesc.textContent = desc;
    });
  });

  modal?.addEventListener('dismiss', () => {
    modal.open = false;
  });
</script>
