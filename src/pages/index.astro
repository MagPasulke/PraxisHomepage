---
import BaseLayout from '../layouts/BaseLayout.astro';

// Load content from JSONC (strip comments before parsing)
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

function parseJsonc(text: string): any {
  return JSON.parse(text.replace(/\/\/.*$/gm, '').replace(/\/\*[\s\S]*?\*\//g, ''));
}

const contentDir = resolve(process.cwd(), 'content');
const team = parseJsonc(readFileSync(resolve(contentDir, 'team.jsonc'), 'utf-8'));
const standorteData = parseJsonc(readFileSync(resolve(contentDir, 'standorte.jsonc'), 'utf-8'));
const aktuelles = parseJsonc(readFileSync(resolve(contentDir, 'aktuelles.jsonc'), 'utf-8'));
---

<BaseLayout title="Gemeinschaftspraxis Soika – Medizin, die Vertrauen schafft">

  <!-- Hero Section -->
  <section class="bg-warm py-16 lg:py-24 overflow-hidden">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text content -->
        <div>
          <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-4">Gemeinschaftspraxis Soika</p>
          <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-primary leading-tight mb-6">
            Medizin, die<br/>Vertrauen schafft.
          </h1>
          <p class="text-lg text-gray-600 mb-8 max-w-lg">
            Ihre hausärztliche Versorgung an den Standorten Schopfloch und Dornstetten.
          </p>
          <div class="flex flex-wrap items-center gap-4">
            <a href="#kontakt" class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-full text-sm font-medium hover:bg-primary-light transition-colors shadow-lg shadow-primary/20">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Termin vereinbaren
            </a>
          </div>
          {aktuelles.news?.length > 0 && (
            <div class="mt-8 max-w-lg bg-white rounded-xl border border-gray-100 shadow-sm p-5">
              <div class="flex items-center gap-2 mb-3">
                <span class="flex-shrink-0 w-2 h-2 bg-accent rounded-full"></span>
                <p class="text-accent font-semibold text-xs uppercase tracking-wider">Aktuelles</p>
              </div>
              <ul class="space-y-4">
                {aktuelles.news.map((item: any) => (
                  <li class="flex flex-col">
                    <span class="text-sm font-semibold text-primary">{item.title}</span>
                    {item.intro && <span class="text-sm text-gray-600 mt-0.5">{item.intro}</span>}
                    {item.dates?.length > 0 && (
                      <ul class="mt-1 space-y-0.5">
                        {item.dates.map((d: string) => (
                          <li class="text-sm text-gray-700 font-medium">{d}</li>
                        ))}
                      </ul>
                    )}
                    {item.note && <span class="text-xs text-gray-500 mt-1">{item.note}</span>}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        <!-- Right: Image -->
        <div class="relative">
          <div class="aspect-[4/3] bg-gray-200 rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/misc/IMG_4895.png" alt="Gemeinschaftspraxis Soika" class="w-full h-full object-cover" loading="eager" />
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-accent/10 rounded-2xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="py-16 bg-white">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-6">
        <!-- Erfahrenes Team -->
        <div class="flex items-start gap-4 p-6 bg-warm rounded-xl border border-gray-100">
          <div class="flex-shrink-0 w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary mb-1">Erfahrenes Team</h3>
            <p class="text-sm text-gray-600">Kompetente und einfühlsame Betreuung für Ihre Gesundheit</p>
          </div>
        </div>
        <!-- Ganzheitliche Medizin -->
        <div class="flex items-start gap-4 p-6 bg-warm rounded-xl border border-gray-100">
          <div class="flex-shrink-0 w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary mb-1">Ganzheitliche Medizin</h3>
            <p class="text-sm text-gray-600">Individuelle Betreuung für Ihr Wohlbefinden</p>
          </div>
        </div>
        <!-- Engagiertes Team -->
        <div class="flex items-start gap-4 p-6 bg-warm rounded-xl border border-gray-100">
          <div class="flex-shrink-0 w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <h3 class="font-semibold text-primary mb-1">Engagiertes Team</h3>
            <p class="text-sm text-gray-600">Für Sie vor Ort</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leistungen Section -->
  <section id="leistungen" class="py-20 bg-warm border-t border-gray-100">
    <div class="max-w-[1280px] mx-auto px-6">
      <p class="text-accent font-semibold text-xs uppercase tracking-wider mb-3">Leistungen</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-primary leading-tight mb-4">Unsere Leistungen</h2>
      <p class="text-gray-600 max-w-2xl mb-12">
        In unseren Praxen in Schopfloch und Dornstetten erhalten Sie ein umfassendes hausärztliches Angebot.
      </p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Diagnostikangebot</h3>
          <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
            <li>Laborchemische Untersuchungen (Blut, Urin, Stuhl, Abstriche)</li>
            <li>Ruhe-, Belastungs- und Langzeit-EKG</li>
            <li>Langzeit-Blutdruckmessung</li>
            <li>Lungenfunktionstest</li>
            <li>Ultraschalluntersuchungen</li>
          </ul>
        </div>
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Kleine Chirurgie & Laserbehandlung</h3>
          <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
            <li>Entfernung von gutartigen Hautveränderungen</li>
            <li>Wundversorgung</li>
            <li>Chirurgische Verbände</li>
          </ul>
        </div>
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Vorsorgeuntersuchungen</h3>
          <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
            <li>Check-up 35: Gesundheitsuntersuchung ab dem 35. Lebensjahr</li>
            <li>Kinder- und Jugendvorsorgeuntersuchung</li>
            <li>Krebsvorsorge</li>
            <li>Hautkrebsscreening</li>
          </ul>
        </div>
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Akupunktur</h3>
          <p class="text-sm text-gray-600">
            Akupunktur kann bei akuten und chronischen Schmerzen des Bewegungssystems, neurologischen Erkrankungen wie Migräne, Suchtkrankheiten, Beschwerden des Verdauungssystems und vielem mehr helfen.
          </p>
        </div>
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Psychosomatische Grundversorgung</h3>
          <p class="text-sm text-gray-600">
            Wir helfen Ihnen, psychische und psychosomatische Erkrankungen zu diagnostizieren und begleiten Sie langfristig auf Ihrem Weg zur Genesung.
          </p>
        </div>
        <div class="bg-white p-7 rounded-xl border border-gray-100 shadow-sm">
          <h3 class="text-lg font-bold text-primary mb-3">Weitere Leistungen</h3>
          <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
            <li>Hausbesuche, Alten- und Pflegeheimbetreuung</li>
            <li>Gutachten, Atteste, Reha-Anträge</li>
            <li>Injektionstherapie hochdosierter Vitaminpräparate</li>
            <li>Impfmedizinische Beratung</li>
            <li>Disease-Management-Programme (DMP)</li>
            <li>Atemschutzuntersuchung G 26</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section id="team" class="py-20 bg-white border-t border-gray-100">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-12 items-start">
        <!-- Left text -->
        <div>
          <p class="text-accent font-semibold text-xs uppercase tracking-wider mb-3">Unser Team</p>
          <h2 class="text-3xl lg:text-4xl font-bold text-primary leading-tight mb-6">
            Für Ihre Gesundheit da – mit Herz und Kompetenz.
          </h2>
          <p class="text-gray-600 mb-8">
            Unser erfahrenes Team aus Ärztinnen und medizinischen Fachkräften begleitet Sie in allen Fragen rund um Ihre Gesundheit.
          </p>
        </div>
        <!-- Right: Team grid -->
        <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-7 gap-6">
          {team.aerzte.map((person: any, i: number) => (
            <div class="text-center">
              {person.hours ? (
                <button
                  type="button"
                  class="group text-center w-full cursor-pointer focus:outline-none"
                  data-dialog-open={`arzt-${i}`}
                  aria-haspopup="dialog"
                >
                  <div class="aspect-square bg-gray-100 rounded-full overflow-hidden mb-3 mx-auto w-24 h-24 lg:w-28 lg:h-28 border-4 border-white shadow-md transition group-hover:shadow-lg group-hover:border-accent/40">
                    <img src={person.image} alt={person.name} class="w-full h-full object-cover object-top" loading="lazy" />
                  </div>
                  <h4 class="text-xs font-semibold text-primary leading-tight">{person.name}</h4>
                  <p class="text-[11px] text-gray-500 mt-0.5">{person.role}</p>
                  <span class="inline-flex items-center gap-1 mt-1.5 text-[11px] font-medium text-accent group-hover:underline">
                    Sprechzeiten
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </span>
                </button>
              ) : (
                <div class="text-center">
                  <div class="aspect-square bg-gray-100 rounded-full overflow-hidden mb-3 mx-auto w-24 h-24 lg:w-28 lg:h-28 border-4 border-white shadow-md">
                    <img src={person.image} alt={person.name} class="w-full h-full object-cover object-top" loading="lazy" />
                  </div>
                  <h4 class="text-xs font-semibold text-primary leading-tight">{person.name}</h4>
                  <p class="text-[11px] text-gray-500 mt-0.5">{person.role}</p>
                </div>
              )}
            </div>
          ))}
        </div>

        <!-- Sprechzeiten Pop-ups -->
        {team.aerzte.map((person: any, i: number) => (
          person.hours && (
            <dialog id={`arzt-${i}`} class="sprechzeiten-dialog m-auto backdrop:bg-black/50 rounded-2xl p-0 w-[90vw] max-w-md shadow-2xl">
              <div class="p-6">
                <div class="flex items-start justify-between gap-4 mb-4">
                  <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full overflow-hidden flex-shrink-0 border-2 border-white shadow">
                      <img src={person.image} alt={person.name} class="w-full h-full object-cover object-top" />
                    </div>
                    <div>
                      <h4 class="text-base font-semibold text-primary leading-tight">{person.name}</h4>
                      <p class="text-xs text-gray-500">{person.role}</p>
                    </div>
                  </div>
                  <button type="button" class="text-gray-400 hover:text-primary transition" data-dialog-close aria-label="Schließen">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                </div>
                <p class="text-sm font-semibold text-primary mb-3">Sprechzeiten</p>
                <div class="space-y-4">
                  {Object.entries(person.hours).map(([standort, tage]: [string, any]) => (
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-wide text-accent mb-1.5">{standort}</p>
                      <table class="w-full text-sm">
                        <tbody>
                          {Object.entries(tage).map(([tag, zeit]: [string, any]) => (
                            <tr class="border-b border-gray-100 last:border-0">
                              <td class="py-1.5 pr-4 text-gray-600 whitespace-nowrap">{tag}</td>
                              <td class="py-1.5 text-right text-primary font-medium">{zeit}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  ))}
                </div>
              </div>
            </dialog>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits bar -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-[1280px] mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-primary">Flexible Sprechzeiten</p>
            <p class="text-xs text-gray-500">und Termine</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-primary">Telefonische Erreichbarkeit</p>
            <p class="text-xs text-gray-500">und Beratung</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-primary">Engagiertes Team</p>
            <p class="text-xs text-gray-500">Für Sie vor Ort</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-primary">Persönliche Betreuung</p>
            <p class="text-xs text-gray-500">und menschlich</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Standort Details -->
  <section id="kontakt" class="py-20 bg-warm">
    <span id="praxis" class="block -mt-20 pt-20"></span>
    <div class="max-w-[1280px] mx-auto px-6">
      <h2 class="text-2xl font-bold text-primary mb-10">Kontakt &amp; Öffnungszeiten</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {standorteData.standorte.map((standort: any) => (
          <div class="bg-white p-8 rounded-xl shadow-sm border border-gray-100">
            <h3 class="text-xl font-bold text-primary mb-4">{standort.name}</h3>
            <address class="not-italic text-sm text-gray-600 space-y-2 mb-6">
              <p>{standort.address}, {standort.zip}</p>
              <p>Tel: <a href={`tel:${standort.phone.replace(/[\s\/]/g, '')}`} class="text-accent hover:text-accent-dark font-medium">{standort.phone}</a></p>
              <p>Fax: {standort.fax}</p>
              <p>E-Mail: <a href={`mailto:${standort.email}`} class="text-accent hover:text-accent-dark font-medium">{standort.email}</a></p>
            </address>
            <h4 class="text-sm font-semibold text-primary mb-3">Öffnungszeiten</h4>
            <table class="text-sm text-gray-600 w-full">
              <tbody>
                {Object.entries(standort.hours).map(([day, time]) => (
                  <tr class="border-b border-gray-100 last:border-0">
                    <td class="py-2 font-medium pr-4 text-primary/80">{day}</td>
                    <td class="py-2">{time as string}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-dialog-open]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-dialog-open');
      const dialog = id ? document.getElementById(id) : null;
      if (dialog instanceof HTMLDialogElement) dialog.showModal();
    });
  });

  document.querySelectorAll<HTMLDialogElement>('dialog.sprechzeiten-dialog').forEach((dialog) => {
    dialog.querySelector('[data-dialog-close]')?.addEventListener('click', () => dialog.close());
    // Close when clicking on the backdrop
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>
